# Database
DATABASE_URL=postgresql+asyncpg://headlines:headlines@db:5432/headlines
POSTGRES_USER=headlines
POSTGRES_PASSWORD=headlines
POSTGRES_DB=headlines

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_AI_API_KEY=your-key-here

# Admin
ADMIN_PASSWORD=change-me-in-production

# Briefing
BRIEFING_TIMEZONE=America/New_York

# Frontend (used in Next.js)
INTERNAL_API_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:80

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:3000

# Scheduler (set true for single-process deployment)
RUN_SCHEDULER=false

# JWT signing (optional, defaults to ADMIN_PASSWORD if empty)
JWT_SECRET=
